# Exchange (research phase doesn't need API keys — public data only)
EXCHANGE_ID=binanceusdm
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_TESTNET=true

# Data acquisition
DATA_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,HYPEUSDT
DATA_START_DATE=
DATA_END_DATE=
DATA_ROOT=./data

# Backtest costs (fill with actual current Binance USD-M Futures fee schedule —
# verify current rates, don't assume these are still correct)
TAKER_FEE_BPS=5.0
MAKER_FEE_BPS=2.0
SLIPPAGE_BPS=3.0

# Logging
LOG_LEVEL=INFO

# Binance USD-M TESTNET keys (play money; separate from mainnet).
# Get at https://testnet.binancefuture.com. Used by scripts/testnet_smoke.py.
# NEVER commit real keys; NEVER put mainnet keys here.
BINANCE_TESTNET_KEY=
BINANCE_TESTNET_SECRET=
